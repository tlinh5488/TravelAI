<krpano version="1.23" title="Virtual Tour" showlog="true">

    <action name="action_bounce">
        tween(hotspot[%1].oy, -8, 1.0, easeInOutSine, 
            tween(hotspot[%1].oy, 20, 1.0, easeInOutSine, action_bounce(%1));
        );
    </action>
	
	<action name="action_stop_bounce">
        stoptween(hotspot[%1].oy);
        tween(hotspot[%1].oy, 15, 0.5, easeOutQuad); </action>

    <action name="action_pulse">
        set(hotspot[%1].alpha, 0.6); 
        set(hotspot[%1].scale, 0.3);
        tween(hotspot[%1].alpha, 0.0, 2.0, easeOutQuad);
        tween(hotspot[%1].scale, 1.3, 2.0, easeOutQuad, action_pulse(%1));
    </action>

    <action name="add_pulse_base">
        txtadd(bname, %1, '_base');
        addhotspot(get(bname));
        
        set(hotspot[get(bname)].type, 'text');
        copy(hotspot[get(bname)].ath, hotspot[%1].ath);
        copy(hotspot[get(bname)].atv, hotspot[%1].atv);
        
        set(hotspot[get(bname)].width, 50); set(hotspot[get(bname)].height, 50);
        set(hotspot[get(bname)].bgroundedge, 25);
        set(hotspot[get(bname)].bgcolor, 0xFF0000); 
        set(hotspot[get(bname)].bgalpha, 0.5);
        set(hotspot[get(bname)].enabled, false); set(hotspot[get(bname)].distorted, true);
        
        txtadd(pulse_cmd, 'action_pulse(', get(bname), ')');
        set(hotspot[get(bname)].onloaded, get(pulse_cmd));
    </action>

<action name="add_hotspot_label">
        txtadd(lname, %1, '_lbl');
        addhotspot(get(lname));
        
        set(hotspot[get(lname)].type, 'text');
        
        txtadd(myhtml, '<div style="background: rgba(255, 255, 255, 0.95); 
		color: #900000; padding: 4px 12px; border-radius: 15px; 
		border: 1px solid rgba(255, 0, 0, 0.3); 
		font-family: \'Segoe UI\', Helvetica, Arial, sans-serif; 
		font-size: 10px; font-weight: 700; text-transform: uppercase; box-shadow: 0 3px 8px rgba(255, 0, 0, 0.15); display: inline-block;">📍 ', get(hotspot[%1].tooltip), '</div>');
        set(hotspot[get(lname)].html, get(myhtml)); 
        
        copy(hotspot[get(lname)].ath, hotspot[%1].ath); 
        copy(hotspot[get(lname)].atv, hotspot[%1].atv);
        
        set(hotspot[get(lname)].oy, 25); 
        set(hotspot[get(lname)].edge, 'top');
        set(hotspot[get(lname)].distorted, false); 
        set(hotspot[get(lname)].enabled, false);
        set(hotspot[get(lname)].zorder, 100);
        set(hotspot[get(lname)].bg, false); 
    </action>

    <include url="skin/vtourskin.xml" />
    <skin_settings maps="false" gyro="true" webvr="true" thumbs="true" title="true" tooltips_hotspots="false" />

<style name="style_dinh_vi_thong_minh" 
       url="skin/pin.png"
       scale="0.08"  
       edge="bottom"
       ox="3" 
       oy="10"
       distorted="false"
       onloaded="add_pulse_base(get(name)); add_hotspot_label(get(name));"
       
       onover="tween(scale, 0.18, 0.3, easeOutBack); tween(ox, 4, 0.3, easeOutBack); action_bounce(get(name));" 
       
       onout="tween(scale, 0.15, 0.3); tween(ox, 3, 0.3); action_stop_bounce(get(name));"
       
       onclick="skin_hotspotstyle_click();"
       />

